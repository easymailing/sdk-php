{
  "name": "easymailing/sdk-php",
  "description": "Official Easymailing SDK for PHP backends.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/easymailing/easymailing-sdk",
  "support": {
    "issues": "https://github.com/easymailing/easymailing-sdk/issues",
    "source": "https://github.com/easymailing/easymailing-sdk/tree/main/packages/php"
  },
  "require": {
    "php": "^8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.50",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^10.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.0 || ^2.0",
    "psr/log": "^2.0 || ^3.0"
  },
  "suggest": {
    "psr/http-client": "Required to use Psr18Transport (Guzzle, Symfony HttpClient, etc.)",
    "psr/http-factory": "Required to use Psr18Transport (PSR-17 request/stream factories)",
    "psr/log": "Required to use Psr3EventListener (bridges SDK telemetry events to any PSR-3 logger)"
  },
  "autoload": {
    "psr-4": {
      "Easymailing\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Easymailing\\Sdk\\Tests\\": "tests/",
      "Easymailing\\Sdk\\Tests\\Helpers\\": "tests/Helpers/"
    }
  },
  "scripts": {
    "test": "phpunit --testsuite default",
    "test:e2e": "phpunit --testsuite e2e",
    "analyse": "phpstan analyse src tests --level=8",
    "generate:webhooks": "php scripts/generate-webhook-events.php",
    "generate": [
      "@php scripts/generate.php",
      "@generate:webhooks"
    ],
    "check": [
      "@generate",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  }
}
